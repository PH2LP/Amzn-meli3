    "bullet_point": [
      {
        "language_tag": "en_US",
        "value": "Easy-to-use running watch monitors heart rate (this is not a medical device) at the wrist and uses GPS to track how far, how fast and where you’ve run.Special Feature:Bluetooth.",
        "marketplace_id": "ATVPDKIKX0DER"
      },
      {
        "language_tag": "en_US",
        "value": "Battery life: up to 2 weeks in smartwatch mode; up to 20 hours in GPS mode",
        "marketplace_id": "ATVPDKIKX0DER"
      },
      {
        "language_tag": "en_US",
        "value": "Plan your race day strategy with the PacePro feature (not compatible with on-device courses), which offers GPS-based pace guidance for a selected course or distance",
        "marketplace_id": "ATVPDKIKX0DER"
      },
      {
        "language_tag": "en_US",
        "value": "Run your best with helpful training tools, including race time predictions and finish time estimates",
        "marketplace_id": "ATVPDKIKX0DER"
      },
      {
        "language_tag": "en_US",
        "value": "Track all the ways you move with built-in activity profiles for running, cycling, track run, virtual run, pool swim, Pilates, HIIT, breathwork and more",
        "marketplace_id": "ATVPDKIKX0DER"
      },
      {
        "language_tag": "en_US",
        "value": "Tune in to your body with advanced wellness features, such as intensity minutes, fitness age, all-day respiration and more",
        "marketplace_id": "ATVPDKIKX0DER"
      },
      {
        "language_tag": "en_US",
        "value": "Customize your watch with free watch faces, data fields, apps and widgets from the Connect IQ Store (requires Garmin Connect app and Connect IQ app loaded on a compatible smartphone)",
        "marketplace_id": "ATVPDKIKX0DER"
      },
      {
        "language_tag": "en_US",
        "value": "Take the guesswork out of training with suggested workouts of varying intensities based on your training history, fitness level and recovery time",
        "marketplace_id": "ATVPDKIKX0DER"
      }
    ],
